POSTGRES_DB=medarchive
POSTGRES_USER=medarchive
POSTGRES_PASSWORD=medarchive
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://medarchive:medarchive@postgres:5432/medarchive
REDIS_URL=redis://redis:6379/0

BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
STORAGE_DIR=/app/storage
OCR_PROVIDER=auto
GOOGLE_VISION_LANGUAGE_HINTS_RAW=ru,en
DOCUMENT_AI_PROJECT_ID=central-trees-491011-c5
DOCUMENT_AI_LOCATION=us
DOCUMENT_AI_PROCESSOR_NAME=
DOCUMENT_AI_PROCESSOR_DISPLAY_NAME=medarchive-pdf-ocr
DOCUMENT_AI_PROCESSOR_TYPE=OCR_PROCESSOR
DOCUMENT_AI_AUTO_CREATE_PROCESSOR=true
DOCUMENT_AI_BATCH_PAGES=5
# Inside Docker, point this to a mounted service-account JSON in /app/credentials
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/document-ai.json
GEMINI_API_KEY=
GEMINI_PDF_MODEL=gemini-2.5-flash
GEMINI_PDF_BATCH_SIZE=5
PDF_OCR_DPI=220
